# --- Required for the API (see src/utils/envValidator.ts) ---
NODE_ENV=development
PORT=3000
JWT_SECRET=use-at-least-32-random-characters-here
JWT_REFRESH_SECRET=use-another-32-plus-char-secret-in-production

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use real newlines or \n in the deployed env; validator expects the full key
FIREBASE_PRIVATE_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Production CORS / realtime ---
# Primary browser app URL (also allowed for Socket.IO in production)
FRONTEND_URL=https://www.example.com
# Optional extra origins, comma-separated (staging, admin site, etc.)
# CORS_ORIGINS=https://staging.example.com

# --- Resend (transactional email) — https://resend.com/docs ---
RESEND_API_KEY=re_xxxxxxxx
# Must be a verified sender in Resend, e.g. "Sneaker Store <onboarding@resend.dev>"
RESEND_FROM_EMAIL=
# Optional
RESEND_REPLY_TO=
# Path on FRONTEND_URL for email verification (default: verify-email → /verify-email?token=...)
# EMAIL_VERIFICATION_PATH=verify-email

# --- Password reset rate limits (optional overrides) ---
# PW_RESET_IP_MAX=5
# Max requests per IP per 15 minutes for POST /forgot-password
# PW_RESET_EMAIL_MAX=3
# Max forgot-password requests per email per hour (normalized, hashed in memory)
# PW_RESET_TOKEN_IP_MAX=20
# Max POST /reset-password (JWT) attempts per IP per 15 minutes

# --- Optional ---
LOG_LEVEL=info
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=300
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Memory (optional; platforms often set NODE_OPTIONS themselves)
NODE_OPTIONS=--max-old-space-size=2048

# Analytics
ANALYTICS_MAX_BATCH_SIZE=1000
ANALYTICS_CACHE_TTL=300
